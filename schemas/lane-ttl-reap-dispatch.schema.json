{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://raw.githubusercontent.com/tinyland-inc/site.scaffold/main/docs/schemas/lane-ttl-reap-dispatch.schema.json",
	"title": "Tinyland lane lifecycle reap repository_dispatch payload",
	"description": "Canonical scheduled cleanup payload. Spokes request a TTL-only or lifecycle sweep; Blahaj owns listing, PR-state verification, and idempotent destruction of lane environments.",
	"type": "object",
	"required": ["event_type", "client_payload"],
	"additionalProperties": false,
	"properties": {
		"event_type": {
			"type": "string",
			"pattern": "^[a-z][a-z0-9-]+-lane-ttl-reap$"
		},
		"client_payload": {
			"oneOf": [
				{ "$ref": "#/$defs/ttlOnlyPayload" },
				{ "$ref": "#/$defs/lifecyclePayload" }
			]
		}
	},
	"$defs": {
		"spoke": {
			"type": "string",
			"pattern": "^[a-z][a-z0-9-]{1,62}$"
		},
		"domain": {
			"type": "string",
			"format": "hostname"
		},
		"requestedAt": {
			"type": "string",
			"format": "date-time"
		},
		"sourceRepository": {
			"type": "string",
			"pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
		},
		"reapReason": {
			"enum": ["ttl-expired", "pr-closed", "capacity-pressure"]
		},
		"ttlOnlyPayload": {
			"type": "object",
			"required": ["schema_version", "operation", "spoke", "domain", "requested_at", "dry_run"],
			"additionalProperties": false,
			"properties": {
				"schema_version": { "const": 1 },
				"operation": { "const": "reap-expired" },
				"spoke": { "$ref": "#/$defs/spoke" },
				"domain": { "$ref": "#/$defs/domain" },
				"requested_at": { "$ref": "#/$defs/requestedAt" },
				"dry_run": { "type": "boolean" }
			}
		},
		"lifecyclePayload": {
			"type": "object",
			"required": [
				"schema_version",
				"operation",
				"spoke",
				"domain",
				"source_repository",
				"requested_at",
				"dry_run",
				"reap_reasons",
				"max_reaps",
				"lane_manifest"
			],
			"additionalProperties": false,
			"properties": {
				"schema_version": { "const": 2 },
				"operation": { "const": "reap-lifecycle" },
				"spoke": { "$ref": "#/$defs/spoke" },
				"domain": { "$ref": "#/$defs/domain" },
				"source_repository": { "$ref": "#/$defs/sourceRepository" },
				"requested_at": { "$ref": "#/$defs/requestedAt" },
				"dry_run": { "type": "boolean" },
				"reap_reasons": {
					"type": "array",
					"minItems": 1,
					"uniqueItems": true,
					"items": { "$ref": "#/$defs/reapReason" }
				},
				"max_reaps": {
					"type": "integer",
					"minimum": 1,
					"maximum": 100
				},
				"min_age_hours": {
					"type": "integer",
					"minimum": 0,
					"maximum": 720
				},
				"lane_manifest": {
					"type": "object",
					"required": ["path", "lane_mode", "lanes"],
					"additionalProperties": false,
					"properties": {
						"path": {
							"type": "string",
							"minLength": 1
						},
						"lane_mode": {
							"type": "string",
							"pattern": "^[a-z][a-z0-9-]{0,30}$"
						},
						"default_ttl_hours": {
							"type": "integer",
							"minimum": 1,
							"maximum": 720
						},
						"tailnet_domain": {
							"type": "string",
							"format": "hostname"
						},
						"lanes": {
							"type": "array",
							"minItems": 1,
							"maxItems": 16,
							"items": {
								"type": "object",
								"required": ["name", "deployment_style"],
								"additionalProperties": false,
								"properties": {
									"name": {
										"type": "string",
										"pattern": "^[a-z][a-z0-9-]{0,30}$"
									},
									"deployment_style": {
										"type": "string",
										"pattern": "^[a-z][a-z0-9-]{0,40}$"
									},
									"domain": {
										"type": "string",
										"format": "hostname"
									}
								}
							}
						}
					}
				}
			}
		}
	}
}
